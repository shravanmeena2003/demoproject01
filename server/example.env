# Copy this file to `.env` and adjust values for local development.
#   cp example.env .env        (macOS / Linux)
#   copy example.env .env      (Windows)

NODE_ENV=development
PORT=5000

# MongoDB (local Docker or Atlas connection string)
MONGODB_URI=mongodb://localhost:27017/smart-leads

# JWT — use a long random string in production (min 16 characters)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend origin for CORS
CLIENT_URL=http://localhost:5173

# Rate limiting (15 min window, 100 requests per IP by default)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
